{%- comment -%}
  Promo Banner — Offre de lancement Nakree
  Visible avec countdown. Le visiteur peut fermer (localStorage).
{%- endcomment -%}

<div id="PromoBanner" class="promo-banner" style="display:none;" role="banner" aria-label="Promotion Nakree">
  <div class="promo-banner__inner">
    <span class="promo-banner__emoji">&#x1F381;</span>
    <span class="promo-banner__text">
      Offre de lancement : <strong>-10%</strong> avec le code
    </span>
    <button type="button" class="promo-banner__code" onclick="navigator.clipboard.writeText('NAKREE10');this.textContent='Copie !';setTimeout(function(){document.querySelector('.promo-banner__code').textContent='NAKREE10';},1500);" title="Cliquer pour copier">NAKREE10</button>
    <span class="promo-banner__sep">&bull;</span>
    <span class="promo-banner__timer" id="PromoCountdown">--j --h --m --s</span>
    <button type="button" class="promo-banner__close" aria-label="Fermer" onclick="document.getElementById('PromoBanner').style.display='none';localStorage.setItem('promo_banner_closed','nakree10');">&times;</button>
  </div>
</div>

<style>
  .promo-banner {
    background: linear-gradient(135deg, #C4A265 0%, #a8893e 50%, #8a6f2a 100%);
    color: #fff;
    font-family: var(--font-sans, system-ui, sans-serif);
    font-size: 0.85rem;
    line-height: 1.4;
    position: relative;
    z-index: 9999;
    overflow: hidden;
  }
  .promo-banner__inner {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 0.55rem 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .promo-banner__emoji { font-size: 1.1rem; }
  .promo-banner__text { white-space: nowrap; }
  .promo-banner__text strong { font-weight: 800; }
  .promo-banner__code {
    background: #fff;
    color: #a8893e;
    font-weight: 800;
    font-size: 0.85rem;
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
    border: 2px dashed rgba(255,255,255,0.5);
    cursor: pointer;
    font-family: monospace;
    letter-spacing: 0.05em;
    transition: transform 0.15s;
  }
  .promo-banner__code:hover { transform: scale(1.06); }
  .promo-banner__sep { opacity: 0.6; font-size: 0.7rem; }
  .promo-banner__timer { font-weight: 700; font-variant-numeric: tabular-nums; letter-spacing: 0.02em; white-space: nowrap; }
  .promo-banner__close {
    position: absolute;
    right: 0.6rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: rgba(255,255,255,0.7);
    font-size: 1.3rem;
    cursor: pointer;
    padding: 0.2rem 0.4rem;
    line-height: 1;
  }
  .promo-banner__close:hover { color: #fff; }
  @media (max-width: 600px) {
    .promo-banner__inner { font-size: 0.78rem; padding: 0.5rem 2rem 0.5rem 0.6rem; gap: 0.3rem; }
    .promo-banner__sep { display: none; }
    .promo-banner__timer { width: 100%; text-align: center; font-size: 0.75rem; margin-top: 0.15rem; }
  }
</style>

<script>
(function() {
  var banner = document.getElementById('PromoBanner');
  if (!banner) return;

  // Always-on countdown: resets every 24h per visitor via localStorage
  var STORAGE_KEY_END = 'nakree_promo_end';
  var endStr = localStorage.getItem(STORAGE_KEY_END);
  var endTime;
  if (endStr) {
    endTime = parseInt(endStr, 10);
    if (Date.now() >= endTime) {
      // Reset for another 24h cycle
      endTime = Date.now() + 86400000;
      localStorage.setItem(STORAGE_KEY_END, String(endTime));
    }
  } else {
    endTime = Date.now() + 86400000;
    localStorage.setItem(STORAGE_KEY_END, String(endTime));
  }

  if (localStorage.getItem('promo_banner_closed') === 'nakree10') return;

  banner.style.display = 'block';

  var timerEl = document.getElementById('PromoCountdown');

  function tick() {
    var diff = endTime - Date.now();
    if (diff <= 0) {
      banner.style.display = 'none';
      return;
    }
    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    timerEl.textContent = 'Expire dans ' + h + 'h ' + (m < 10 ? '0' : '') + m + 'm ' + (s < 10 ? '0' : '') + s + 's';
    requestAnimationFrame(function() { setTimeout(tick, 1000); });
  }
  tick();
})();
</script>
