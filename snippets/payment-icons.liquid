<div class="flex flex-wrap justify-center gap-2">
  {%- comment -%} Render Shopify-enabled payment icons natively {%- endcomment -%}
  {%- for type in shop.enabled_payment_types -%}
    <span class="inline-flex items-center justify-center" aria-label="{{ type | replace: '_', ' ' | capitalize }}">
      {{ type | payment_type_svg_tag: class: 'payment-icon' }}
    </span>
  {%- endfor -%}
</div>

<style>
  .payment-icon { width: 38px; height: 24px; display: inline-block; }
</style>
