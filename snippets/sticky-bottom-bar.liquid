<div class="sticky-bottom-bar" data-sticky-bar>
  <div class="container flex items-center justify-between gap-4" style="padding: 1rem 0;">
    <div class="flex items-center gap-3" style="min-width:0; flex:1;">
      <div style="height:44px; width:44px; flex-shrink:0; border-radius:10px; background:var(--color-muted, #F5F0E8); display:flex; align-items:center; justify-content:center; padding:4px;">
        <span style="font-size:1.5rem;">&#x1F9B7;</span>
      </div>
      <div class="sticky-bar-text" style="min-width:0; flex:1;">
        <p class="sticky-bar-title" style="font-size:0.8rem; font-weight:600; line-height:1.15; margin:0 0 4px 0; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">Accelerateur LED Nakree</p>
        <div style="display:flex; align-items:center; gap:0.4rem; flex-wrap:wrap;">
          <span style="font-size:0.95rem; font-weight:700; color:var(--color-primary);" data-sticky-price>&euro;19,95</span>
          <span style="font-size:0.7rem; color:#DC2626; font-weight:600;">Offre de lancement</span>
        </div>
      </div>
    </div>
    <button type="button" class="sticky-bar-cta" data-sticky-add style="background:var(--color-primary); color:var(--color-primary-fg, #fff); border:0; cursor:pointer; text-transform:none; font-weight:700; border-radius:9999px; padding:0.6rem 1.25rem; font-size:0.85rem; flex-shrink:0; white-space:nowrap;">Ajouter au panier</button>
  </div>
</div>

<script>
(function() {
  var bar = document.querySelector('[data-sticky-bar]');
  if (!bar) return;
  var addBtn = bar.querySelector('[data-sticky-add]');
  var isMobile = function() { return window.matchMedia('(max-width: 767px)').matches; };

  function update() {
    var drawerOpen = document.querySelector('[data-cart-drawer]');
    drawerOpen = drawerOpen && drawerOpen.getAttribute('data-open') === 'true';
    if (isMobile()) {
      bar.dataset.mobileAlways = drawerOpen ? 'false' : 'true';
      bar.dataset.visible = 'false';
    } else {
      var shouldShow = window.scrollY > 200 && !drawerOpen;
      bar.dataset.mobileAlways = 'false';
      bar.dataset.visible = shouldShow ? 'true' : 'false';
    }
  }
  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update, { passive: true });
  document.addEventListener('nakree:cart-state', update);
  update();

  if (addBtn) {
    addBtn.addEventListener('click', function() {
      var defaultBundle = document.querySelector('[data-bundle][aria-pressed="true"]') || document.querySelector('[data-bundle]');
      if (!defaultBundle) return;
      var variantId = defaultBundle.dataset.bundleVariant;
      var qty = parseInt(defaultBundle.dataset.bundleQuantity || '1', 10);
      var price = parseFloat(defaultBundle.dataset.bundlePrice);
      var unitPrice = +(price / qty).toFixed(2);
      if (window.NakreeCart) {
        window.NakreeCart.openWith([{
          id: 'main-product',
          variantId: variantId,
          title: defaultBundle.dataset.bundleTitle || 'Produit',
          price: unitPrice,
          quantity: qty,
          image: defaultBundle.dataset.bundleImage || ''
        }]);
      }
      if (window.fbq) {
        window.fbq('track', 'AddToCart', {
          value: price,
          currency: 'EUR',
          content_ids: [variantId],
          content_type: 'product',
          num_items: qty
        });
      }
    });
  }
})();
</script>
