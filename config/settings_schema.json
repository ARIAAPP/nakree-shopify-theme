  {
    "name": "Couleurs",
    "settings": [
      {
        "type": "header",
        "content": "Marque"
      },
      {
        "type": "color",
        "id": "color_primary",
        "label": "Couleur primaire (gold)",
        "default": "#C4A265"
      },
      {
        "type": "color",
        "id": "color_primary_foreground",
        "label": "Texte sur primaire",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Couleur accent (rouge promo)",
        "default": "#dc2626"
      },
      {
        "type": "color",
        "id": "color_accent_foreground",
        "label": "Texte sur accent",
        "default": "#ffffff"
      },
      {
        "type": "header",
        "content": "Fond et texte"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Fond (ivory/cream)",
        "default": "#FDFBF7"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Texte (ink)",
        "default": "#1a1a1a"
