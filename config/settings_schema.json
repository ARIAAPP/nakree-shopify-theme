      {
        "type": "header",
        "content": "Footer"
      },
      {
        "type": "color",
        "id": "color_footer_bg",
        "label": "Fond footer",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_footer_fg",
        "label": "Texte footer",
        "default": "#FDFBF7"
      }
    ]
  },
  {
    "name": "Typographie",
    "settings": [
      {
        "type": "select",
        "id": "font_family",
        "label": "Police",
        "default": "poppins",
        "options": [
          { "value": "poppins", "label": "Poppins" },
          { "value": "inter", "label": "Inter" },
          { "value": "system", "label": "Police systeme" }
        ]
      }
    ]
  },
  {
    "name": "Logo & Identite",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo (optionnel — si vide, texte stylise)"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "label": "Largeur max du logo",
        "min": 80,
        "max": 280,
        "step": 10,
        "unit": "px",
        "default": 140
      },
      {
        "type": "text",
        "id": "brand_text",
        "label": "Nom de la marque (si pas de logo)",
        "default": "Nakrée"
      },
      {
        "type": "text",
        "id": "brand_text_highlight",
        "label": "Mot a mettre en couleur primaire",
        "info": "Ex: 'krée' dans 'Nakrée'",
        "default": "krée"
      }
    ]
  },
  {
    "name": "Tracking & Analytics",
    "settings": [
      {
        "type": "header",
        "content": "Meta Pixel"
      },
      {
        "type": "text",
        "id": "meta_pixel_id",
        "label": "ID du Pixel Meta",
        "default": ""
      },
      {
        "type": "text",
        "id": "meta_domain_verification",
        "label": "Code de verification de domaine Meta",
        "default": ""
      },
      {
        "type": "header",
        "content": "Microsoft Clarity"
      },
      {
        "type": "text",
        "id": "clarity_id",
        "label": "ID Microsoft Clarity",
        "default": ""
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "container_max_width",
        "label": "Largeur max du contenu",
        "min": 1200,
        "max": 1600,
        "step": 50,
        "unit": "px",
        "default": 1400
      },
      {
        "type": "range",
        "id": "border_radius",
        "label": "Arrondi par defaut",
        "min": 0,
        "max": 16,
        "step": 1,
        "unit": "px",
        "default": 12
      }
    ]
  }
]
