<section class="py-16 md:py-20 bg-secondary">
  <div class="container">
    <div class="text-center space-y-2" style="margin-bottom: 2.5rem;">
      <h2 class="text-3xl font-bold">{{ section.settings.title }}</h2>
      <p class="text-muted-foreground">{{ section.settings.subtitle }}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-center">
      <div>
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="Contenu du kit Nakree" width="600" height="600" loading="lazy" decoding="async" class="rounded-2xl" style="width:100%; object-fit:cover;">
        {%- else -%}
          <div class="rounded-2xl" style="background:var(--color-muted); aspect-ratio:1/1; display:flex; align-items:center; justify-content:center;">
            <span style="font-size:5rem;">&#x1F4E6;</span>
          </div>
        {%- endif -%}
      </div>

      <div class="space-y-4">
        {%- for block in section.blocks -%}
          <div class="flex items-start gap-4 rounded-xl bg-background p-4" {{ block.shopify_attributes }} style="border:1px solid var(--color-border);">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary" style="color:var(--color-primary-fg); font-weight:700; font-size:0.95rem;">
              {{ forloop.index }}
            </div>
            <div>
              <p class="text-sm font-bold">{{ block.settings.title }}</p>
              <p class="text-xs text-muted-foreground" style="margin-top:0.25rem;">{{ block.settings.description }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contenu du kit",
  "tag": "section",
  "class": "kit-contents-section",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Ce que contient votre kit Nakree" },
    { "type": "text", "id": "subtitle", "label": "Sous-titre", "default": "Tout ce qu'il vous faut pour un sourire eclatant" },
    { "type": "image_picker", "id": "image", "label": "Image du kit" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Element du kit",
      "settings": [
        { "type": "text", "id": "title", "label": "Nom", "default": "Accelerateur LED Nakree" },
        { "type": "text", "id": "description", "label": "Description", "default": "16 LEDs bleues professionnelles, lumiere froide sans chaleur" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contenu du kit"
    }
  ]
}
{% endschema %}
