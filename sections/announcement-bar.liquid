{%- comment -%}
  Announcement bar — black static bar (Lovable-style)
{%- endcomment -%}

<div class="announcement-bar-static" style="background:#1a1a1a; color:#fff; font-size:0.8rem; font-weight:500; letter-spacing:0.02em; padding:0.6rem 1rem;">
  <div style="max-width:var(--container-max,1400px); margin:0 auto; display:flex; align-items:center; justify-content:center; gap:0.5rem; flex-wrap:wrap;">
    {%- for block in section.blocks -%}
      {%- unless forloop.first -%}
        <span style="opacity:0.4; font-size:0.5rem;">&bull;</span>
      {%- endunless -%}
      <span class="whitespace-nowrap">{{ block.settings.text }}</span>
    {%- endfor -%}
  </div>
</div>

{% render 'promo-banner' %}

{% schema %}
{
  "name": "Barre d'annonce",
  "tag": "div",
  "class": "announcement-bar-section",
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Livraison offerte"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre d'annonce"
    }
  ],
  "enabled_on": {
    "groups": [
      "header"
    ]
  }
}
{% endschema %}
